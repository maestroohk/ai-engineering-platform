@using AiEng.Platform.App.Components.Common
@namespace AiEng.Platform.App.Components.Primitive

<span class="@CssClass">
    @if (Dot)
    {
        <span class="app-badge-dot" aria-hidden="true"></span>
    }
    <span class="app-badge-content">@ChildContent</span>
</span>

@code {
    [Parameter]
    public AppBadgeVariant Variant { get; set; } = AppBadgeVariant.Neutral;

    [Parameter]
    public AppBadgeSize Size { get; set; } = AppBadgeSize.Medium;

    [Parameter]
    public bool Dot { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass =>
        $"app-badge app-badge-{Variant.ToString().ToLowerInvariant()} app-badge-size-{Size.ToString().ToLowerInvariant()}";
}
