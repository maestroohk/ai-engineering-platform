@namespace AiEng.Platform.App.Components.Primitive
@inherits AppButtonBase

<button type="@EffectiveType"
        class="@CssClass"
        disabled="@DisabledOrLoading"
        aria-busy="@Loading.ToString().ToLowerInvariant()"
        aria-disabled="@DisabledOrLoading.ToString().ToLowerInvariant()"
        @onclick="HandleClick"
        @attributes="AdditionalAttributes">
    @if (Loading)
    {
        <span class="app-button-spinner" aria-hidden="true"></span>
    }
    @if (LeftIcon is not null && !Loading)
    {
        <span class="app-button-icon">@LeftIcon</span>
    }
    <span class="app-button-label">@ChildContent</span>
    @if (RightIcon is not null && !Loading)
    {
        <span class="app-button-icon">@RightIcon</span>
    }
</button>
