@namespace AiEng.Platform.App.Components.Shell

<span class="app-user-avatar-slot" aria-label="@AriaLabel" @attributes="AdditionalAttributes">
    <AppAvatar Initials="@Initials" />
</span>

@code {
    [Parameter]
    public string Initials { get; set; } = "?";

    [Parameter]
    public string AriaLabel { get; set; } = "Current user";

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
}
