@namespace AiEng.Platform.App.Components.Shell

<AppShellRegion Name="topbar">
    <AppStack Gap="AppStackGap.Small">
        <AppPageHeader>
            <Title>Top bar lands in M2.3</Title>
            <Description>The application top bar, breadcrumbs, and theme toggle arrive in M2.3 (Top Bar, Breadcrumbs, and Page Headers). The slot reserves the region so M2.3 has a stable target.</Description>
        </AppPageHeader>
        <AppAlert Variant="AppAlertVariant.Information">
            <Title>M2.1 placeholder</Title>
            <Description>This region is intentionally empty. M2.3 replaces it with the real top bar.</Description>
        </AppAlert>
    </AppStack>
</AppShellRegion>
