@page "/not-found"
@attribute [RouteMetadata("/not-found", "Not found", Order = 99, ShowInSidebar = false)]
@layout AppEmptyLayout

<PageTitle>Not found</PageTitle>

<AppPageHeader>
    <Title>Not found</Title>
    <Description>The route you requested is not registered with the platform. Use the link below to return to a known surface.</Description>
</AppPageHeader>

<AppCard>
    <Header>Not found</Header>
    <ChildContent>
        <AppEmptyState>
            <Title>Nothing at this address</Title>
            <Description>The page you tried to reach is not part of the platform. The design system lists every primitive the platform composes against; the dashboard reads the project state.</Description>
            <Actions>
                <a href="/">Open the home page</a>
                <a href="/design-system">Open the design system</a>
            </Actions>
        </AppEmptyState>
    </ChildContent>
</AppCard>
