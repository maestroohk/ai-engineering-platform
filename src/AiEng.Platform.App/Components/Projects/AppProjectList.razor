@using AiEng.Platform.Domain.Projects
@namespace AiEng.Platform.App.Components.Projects

@inject IProjectService ProjectService

@if (IsLoading)
{
    <div class="app-project-list-slot" data-state="loading">
        <AppLoading>
            <Label>Loading projects…</Label>
        </AppLoading>
    </div>
}
else if (LoadError is { } error)
{
    <div class="app-project-list-slot" data-state="error">
        <AppErrorState ErrorCode="m3.load_failed" CorrelationId="@CorrelationId">
            <Title>Cannot load projects</Title>
            <Description>@error</Description>
            <PrimaryAction>
                <AppButton Variant="AppButtonVariant.Primary" @onclick="OnRetryAsync">Retry</AppButton>
            </PrimaryAction>
        </AppErrorState>
    </div>
}
else if (Projects.Count == 0)
{
    <div class="app-project-list-slot" data-state="empty">
        <AppEmptyState>
            <Title>No projects yet</Title>
            <Description>Register a project folder to begin. The platform stores the project in memory for the lifetime of the current process; the durable store lands in M4-A.</Description>
            <Actions>
                <AppButton Variant="AppButtonVariant.Primary"
                           data-testid="empty-register-project"
                           @onclick="OnShowRegister">
                    Register a project
                </AppButton>
            </Actions>
        </AppEmptyState>
    </div>
}
else
{
    <div class="app-project-list-slot" data-state="populated">
        <AppStack Direction="AppStackDirection.Vertical" Gap="AppStackGap.Medium">
            @foreach (var project in Projects)
            {
                <AppProjectCard Project="project"
                                OnRename="@(() => OnShowRename(project))"
                                OnUnregister="@(() => OnShowUnregister(project))" />
            }
        </AppStack>
    </div>
}

<RegisterProjectForm Visible="@ShowRegister"
                     OnCancel="OnHideRegister"
                     OnRegistered="OnRegisteredAsync" />

<RenameProjectForm Visible="@(ShowRename && RenameTarget is not null)"
                   Project="@RenameTarget"
                   OnCancel="OnHideRename"
                   OnRenamed="OnRenamedAsync" />

<ConfirmUnregisterProject Visible="@(ShowUnregister && UnregisterTarget is not null)"
                          Project="@UnregisterTarget"
                          OnCancel="OnHideUnregister"
                          OnUnregistered="OnUnregisteredAsync" />

@code {
    private static readonly string CorrelationId = $"m3-list-{Guid.NewGuid():N}";

    private IReadOnlyList<AiEng.Platform.Domain.Projects.Project> Projects { get; set; } = Array.Empty<AiEng.Platform.Domain.Projects.Project>();

    private bool IsLoading { get; set; } = true;

    private string? LoadError { get; set; }

    private bool ShowRegister { get; set; }

    private bool ShowRename { get; set; }

    private AiEng.Platform.Domain.Projects.Project? RenameTarget { get; set; }

    private bool ShowUnregister { get; set; }

    private AiEng.Platform.Domain.Projects.Project? UnregisterTarget { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    public async Task RefreshAsync()
    {
        await LoadAsync();
        StateHasChanged();
    }

    public void ShowRegisterDialog()
    {
        ShowRegister = true;
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        LoadError = null;
        try
        {
            Projects = await ProjectService.ListAsync();
        }
        catch (Exception ex)
        {
            LoadError = ex.Message;
            Projects = Array.Empty<AiEng.Platform.Domain.Projects.Project>();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task OnRetryAsync() => await LoadAsync();

    private void OnShowRegister()
    {
        ShowRegister = true;
    }

    private void OnHideRegister()
    {
        ShowRegister = false;
    }

    private void OnShowRename(Project project)
    {
        RenameTarget = project;
        ShowRename = true;
    }

    private void OnHideRename()
    {
        ShowRename = false;
        RenameTarget = null;
    }

    private void OnShowUnregister(Project project)
    {
        UnregisterTarget = project;
        ShowUnregister = true;
    }

    private void OnHideUnregister()
    {
        ShowUnregister = false;
        UnregisterTarget = null;
    }

    private async Task OnRegisteredAsync(Project project)
    {
        ShowRegister = false;
        await LoadAsync();
    }

    private async Task OnRenamedAsync(Project project)
    {
        ShowRename = false;
        RenameTarget = null;
        await LoadAsync();
    }

    private async Task OnUnregisteredAsync(Project project)
    {
        ShowUnregister = false;
        UnregisterTarget = null;
        await LoadAsync();
    }
}
