root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{js,mjs,cjs,json,css,md}]
indent_size = 2
end_of_line = lf

[*.{cs,razor,csproj,props,targets,xml,config,json}]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false
