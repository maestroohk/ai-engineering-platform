{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://aieng.platform/schemas/project.json",
  "title": "AI Engineering Platform — Project State",
  "description": "The canonical machine-readable state of the project. The JSON is the source of truth; .ai/state/current.md is the human-readable projection. When the two disagree, the JSON wins; current.md is regenerated.",
  "type": "object",
  "required": [
    "name",
    "version",
    "schema_version",
    "updated_at",
    "updated_by_session",
    "repository",
    "stack",
    "deployment_target",
    "audience",
    "documentation_root"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "$id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "schema_version": { "type": "string" },
    "updated_at": { "type": "string", "format": "date-time" },
    "updated_by_session": { "type": "string" },
    "repository": { "type": "string" },
    "stack": {
      "type": "object",
      "properties": {
        "runtime": { "type": "string" },
        "language": { "type": "string" },
        "ui_framework": { "type": "string" },
        "styling": { "type": "string" },
        "test_runner": { "type": "string" },
        "component_testing": { "type": "string" }
      }
    },
    "deployment_target": { "type": "string" },
    "audience": { "type": "string" },
    "documentation_root": { "type": "string" },
    "documents": {
      "type": "object",
      "description": "The documentation hierarchy (per M0.5 refinement).",
      "properties": {
        "vision": { "type": "string", "description": "Path to VISION.md" },
        "constitution": { "type": "string", "description": "Path to AGENTS.md" },
        "architecture": { "type": "string", "description": "Path to ARCHITECTURE.md" },
        "decisions": { "type": "string", "description": "Path to DECISIONS.md" },
        "product": { "type": "string", "description": "Path to PRODUCT.md" },
        "roadmap": { "type": "string", "description": "Path to ROADMAP.md" },
        "master_delivery_plan": { "type": "string", "description": "Path to master-delivery-plan.md" },
        "standards_root": { "type": "string", "description": "Path to docs/" },
        "ai_layer_root": { "type": "string", "description": "Path to .ai/" }
      }
    }
  }
}
