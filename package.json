{
  "name": "aieng-platform-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend styling foundation for AiEng.Platform. Builds the Tailwind/PostCSS pipeline that emits wwwroot/css/app.css.",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "css:build": "cross-env NODE_ENV=production tailwindcss -i ./src/AiEng.Platform.App/Styles/input.css -o ./src/AiEng.Platform.App/wwwroot/css/app.css --minify",
    "css:watch": "cross-env NODE_ENV=development tailwindcss -i ./src/AiEng.Platform.App/Styles/input.css -o ./src/AiEng.Platform.App/wwwroot/css/app.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "10.4.20",
    "cross-env": "7.0.3",
    "cssnano": "7.0.6",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17"
  }
}
